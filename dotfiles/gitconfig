# vim: set ft=gitconfig:

[alias]
	co = checkout
	switch = switch
	logg = log --color=auto --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
	logp = log --color=auto --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit -p
	logf = log --color=auto --graph --oneline --name-only
[user]
	email = erez.volk@gmail.com
	name = Erez Volk

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true  # use n and N to move between diff sections
#	dark = true      # or light = true, or omit for auto-detection

[merge]
	conflictStyle = zdiff3
