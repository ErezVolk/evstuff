#!/usr/bin/env python3
"""Create venv wrapper for scripts."""
import argparse
import os
import typing as t
from pathlib import Path


class Vrap:
    """Create venv wrapper for scripts."""

    parser: argparse.ArgumentParser
    args: argparse.Namespace

    def usage(self) -> None:
        """Parse command-line arguments."""
        parser = argparse.ArgumentParser()
        parser.add_argument(
            "scripts",
            metavar="SCRIPT",
            type=Path,
            nargs="+",
            help="A venv-needing Python script",
        )
        parser.add_argument(
            "--venv",
            type=Path,
            help="Path to virtual env",
            default=Path.home() / ".local" / "venv",
        )
        parser.add_argument(
            "--bin",
            type=Path,
            help="Where to put the wrappers",
            default=Path.home() / "bin",
        )
        parser.add_argument(
            "-k",
            "--keep-suffix",
            action="store_true",
            help="Keep .py suffix",
        )
        parser.add_argument(
            "-f",
            "--force",
            action="store_true",
            help="Overwrite existing wrappers",
        )
        self.args = parser.parse_args()
        self.parser = parser

    venv: Path

    def main(self) -> None:
        """Create venv wrapper for scripts."""
        self.usage()
        self.venv = self.args.venv.resolve()
        if not self.venv.is_dir():
            self.fail(f"Create {self.args.venv}")
        if not self.args.bin.resolve().is_dir():
            self.fail(f"Create {self.args.bin}")
        missing = [path for path in self.args.scripts if not path.is_file()]
        if missing:
            self.fail(f"Missing: {' '.join(map(str, missing))}")

        for wrappee in self.args.scripts:
            self.wrap_one(wrappee)

    def wrap_one(self, wrappee: Path) -> None:
        """Wrap or link a single script."""
        just_link = self.should_just_link(wrappee)

        wrapper: Path = self.args.bin / wrappee.name
        if not self.args.keep_suffix:
            if wrapper.suffix.lower() == ".py":
                wrapper = wrapper.with_suffix("")
        if wrapper.is_symlink():
            print(f"Removing old symlink {wrapper}")
            wrapper.unlink()
        elif wrapper.is_file() and not self.args.force:
            self.fail(f"Not overwriting: {wrapper}")

        wrappee = wrappee.resolve()
        if just_link:
            print(f"Linking {wrapper}")
            wrapper.symlink_to(wrappee)
        else:
            print(f"Creating {wrapper}")
            with wrapper.open("wt", encoding="utf-8") as fobj:
                fobj.write("#!/bin/sh\n")
                fobj.write("# Generated by vrap\n\n")
                fobj.write(f'source "{self.venv}/bin/activate" && ')
                fobj.write(f'python "{wrappee}" "$@"\n')

            wrapper.chmod(0o755)

    UV_SHEBANG = "#!/usr/bin/env -S uv run --script\n"

    def should_just_link(self, wrappee: Path) -> bool:
        """Check whether we should just link a script."""
        if not os.access(wrappee, os.X_OK):
            return False  # Not executable
        with wrappee.open("r", encoding="utf-8") as fobj:
            return fobj.read(len(self.UV_SHEBANG)) == self.UV_SHEBANG

    def fail(self, message: str) -> t.NoReturn:
        """Handy wrapper around `ArgumentParser.error()`."""
        self.parser.error(message)


if __name__ == "__main__":
    Vrap().main()
